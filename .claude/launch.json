{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "pact-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "web"
    },
    {
      "name": "pact-demo",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-lc", "PACT_CLOCK_MODE=demo uv run uvicorn pact.main:app --port 8010"],
      "port": 8010
    },
    {
      "name": "pact-web-inspect",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-lc", "PACT_API_PROXY=http://127.0.0.1:8011 npm run dev -- --port 5188 --strictPort"],
      "port": 5188,
      "cwd": "web"
    },
    {
      "name": "pact-web-preview",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-lc", "npm run dev -- --port 5199 --strictPort"],
      "port": 5199,
      "cwd": "web"
    }
  ]
}
